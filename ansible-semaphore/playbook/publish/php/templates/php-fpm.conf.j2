;;;;;;;;;;;;;;;;;;;;;
; FPM Configuration ;
;;;;;;;;;;;;;;;;;;;;;

;;;;;;;;;;;;;;;;;;
; Global Options ;
;;;;;;;;;;;;;;;;;;

[global]
; Pid file
; Default Value: none
pid = run/php-fpm.pid

; Error log file
; Default Value: log/php-fpm.log
error_log = /var/log/php83/php-fpm.log

; Send FPM to background. Set to 'no' to keep FPM in foreground for debugging.
; Default Value: yes
daemonize = no

;;;;;;;;;;;;;;;;;;;;
; Pool Definitions ;
;;;;;;;;;;;;;;;;;;;;

[insertlive8]
user = detik
group = detik
listen.owner = detik
listen.group = detik
listen = /tmp/insertlive8.sock
listen.backlog = 65536
listen.allowed_clients = 127.0.0.1
pm = dynamic
pm.max_children = 30
pm.start_servers = 15
pm.min_spare_servers = 10
pm.max_spare_servers = 15
pm.process_idle_timeout = 10s;
pm.max_requests = 500
pm.status_path = /fpmstatus
slowlog = /var/log/php83/$pool.log.slow
request_slowlog_timeout = 5s
request_terminate_timeout = 2m

